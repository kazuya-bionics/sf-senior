<nav id="main-nav" transition:persist class="w-full z-40 fixed top-0 left-0 py-4 px-4 sm:px-6 md:py-6 md:px-8 flex items-center justify-between transition-transform duration-300 will-change-transform">
    <h3 class="text-sm sm:text-base font-semibold shrink-0">
        <a href="/">SF Senior</a>
    </h3>

    <!-- menú desktop -->
    <ul class="hidden md:flex gap-4 lg:gap-6 text-sm">
        <li><a href="/">Inicio</a></li>
        <li><a href="/about">Nosotros</a></li>
        <li><a href="/services">Prestamos</a></li>
        <li><a href="/contact">Contacto</a></li>
    </ul>

    <div class="flex items-center gap-2 sm:gap-3">
        
        <!-- botón hamburguesa (mobile) -->
        <button
            id="mobile-menu-toggle"
            type="button"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="md:hidden flex flex-col justify-center items-center gap-1.5 w-9 h-9 shrink-0"
        >
            <span class="block w-6 h-0.5 bg-neutral-900"></span>
            <span class="block w-6 h-0.5 bg-neutral-900"></span>
            <span class="block w-6 h-0.5 bg-neutral-900"></span>
        </button>
        <!-- id="mobile-menu-toggle" y "mobile-menu" listos para engancharlos con GSAP -->
    </div>

    <!-- panel del menú mobile: oculto por defecto, listo para tu animación GSAP -->
    <div
        id="mobile-menu"
        class="md:hidden fixed inset-0 top-15 z-30 bg-white opacity-0 pointer-events-none"
    >
        <ul class="flex flex-col items-center gap-6 pt-12 text-base">
            <li><a href="/">Inicio</a></li>
            <li><a href="/about">Nosotros</a></li>
            <li><a href="/services">Prestamos</a></li>
            <li><a href="/contact">Contacto</a></li>
            <li>
                <a class="bg-primary text-sm text-background px-4 py-2 rounded-lg" href="/contact">
                    Solicitar Prestamo
                </a>
            </li>
        </ul>
    </div>
</nav>

<script>
    function initNavScroll() {
        const nav = document.getElementById("main-nav") as HTMLElement | null;
        if (!nav || nav.dataset.scrollInit === "true") return;
        nav.dataset.scrollInit = "true";

        let lastY = window.scrollY;
        let ticking = false;
        const hideAfter = 80; // px de scroll antes de empezar a ocultar

        const applyState = () => {
            const currentY = window.scrollY;
            const goingDown = currentY > lastY;

            if (goingDown && currentY > hideAfter) {
                nav.style.transform = "translateY(-120%)";
            } else {
                nav.style.transform = "translateY(0)";
            }

            lastY = currentY;
            ticking = false;
        };

        window.addEventListener(
            "scroll",
            () => {
                if (!ticking) {
                    requestAnimationFrame(applyState);
                    ticking = true;
                }
            },
            { passive: true }
        );
    }

    // corre en la carga inicial y en cada navegación con Page Transitions
    initNavScroll();
    document.addEventListener("astro:page-load", initNavScroll);

    // al entrar a una página nueva, aseguramos que el nav se vea (por si venía oculto)
    document.addEventListener("astro:before-swap", () => {
        const nav = document.getElementById("main-nav") as HTMLElement | null;
        if (nav) nav.style.transform = "translateY(0)";
    });
</script>