---
// Footer.astro
// Requiere: npm install astro-icon @iconify-json/simple-icons
// astro.config.mjs -> integrations: [icon()]
// Tailwind ya debe estar configurado en el proyecto (@astrojs/tailwind o Tailwind v4 con Vite)
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();

const socials = [
  { name: 'Facebook', icon: 'simple-icons:facebook', url: 'https://www.facebook.com/profile.php?id=61585688856707' },
  { name: 'Instagram', icon: 'simple-icons:instagram', url: 'https://www.instagram.com/pres.tamosjubilados' },
  { name: 'TikTok', icon: 'simple-icons:tiktok', url: 'https://www.tiktok.com/@prestamos.pension3' },
];

const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-slate-800 text-slate-200 px-6 pt-12 pb-6">
  <div class="mx-auto max-w-5xl grid grid-cols-1 gap-8 text-center sm:grid-cols-2 sm:text-left md:grid-cols-3">

    <div class="sm:col-span-2 md:col-span-1">
      <p class="text-2xl font-bold text-white">SF Senior</p>
      <p class="mt-2 max-w-[28ch] mx-auto sm:mx-0 text-sm text-slate-400 leading-relaxed">
        Cuidado y compañía para quienes más queremos.
      </p>
    </div>

    <nav aria-label="Enlaces del sitio">
      <ul class="flex flex-col items-center sm:items-start gap-2.5">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-slate-200 transition-colors hover:text-amber-400 focus-visible:text-amber-400 outline-none"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex flex-col items-center sm:items-start gap-3">
      <span class="text-xs uppercase tracking-wider text-slate-400">Síguenos</span>
      <div class="flex gap-3">
        {socials.map((social) => (
          <a
            href={social.url}
            aria-label={social.name}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-slate-200 transition-all hover:-translate-y-0.5 hover:bg-amber-400 hover:text-slate-800 focus-visible:-translate-y-0.5 focus-visible:bg-amber-400 focus-visible:text-slate-800 outline-none"
          >
            <Icon name={social.icon} class="h-5 w-5" />
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="mx-auto mt-10 max-w-5xl border-t border-white/10 pt-6 text-center">
    <p class="text-sm text-slate-400">&copy; {year} SF Senior. Todos los derechos reservados.</p>
  </div>
</footer>