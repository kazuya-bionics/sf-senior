---
// ServicesCarousel.astro
// Requiere Tailwind CSS y astro-icon con el set "lucide" instalado:
//   npm install astro-icon @iconify-json/lucide

import { Icon } from "astro-icon/components";
---

<section class="mx-auto max-w-6xl rounded-3xl bg-neutral-50 px-6 py-12 md:px-12">
  <!-- Encabezado -->
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold text-neutral-900 md:text-4xl">
      Soluciones financieras
      <span class="block text-primary">pensadas para ti</span>
    </h2>
    <p class="mt-4 text-sm leading-relaxed text-neutral-500 md:text-base">
      En Pensiora te ayudamos a encontrar la mejor opción de financiamiento para que
      obtengas un préstamo con mejores condiciones, de forma rápida, segura y con el
      acompañamiento de nuestros asesores durante todo el proceso.
    </p>
  </div>

  <!-- Controles del carrusel (solo visibles cuando hace falta, ej. mobile) -->
  <div class="mt-8 flex items-center justify-end gap-2 md:hidden">
    <button
      id="carousel-prev"
      type="button"
      aria-label="Anterior"
      class="flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-500 transition hover:bg-neutral-100"
    >
      <Icon name="lucide:chevron-left" class="h-5 w-5" />
    </button>
    <button
      id="carousel-next"
      type="button"
      aria-label="Siguiente"
      class="flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-500 transition hover:bg-neutral-100"
    >
      <Icon name="lucide:chevron-right" class="h-5 w-5" />
    </button>
  </div>

  <!-- Carrusel -->
  <ul
    id="services-carousel"
    class="mt-6 flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-2 scrollbar-none [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden md:grid md:grid-cols-4 md:overflow-visible"
  >
    <li class="w-[85%] shrink-0 snap-center rounded-2xl bg-white p-6 shadow-sm md:w-auto">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-50">
        <Icon name="lucide:hand-coins" class="h-6 w-6 text-primary" />
      </div>
      <h3 class="relative mt-4 inline-block pb-2 text-base font-semibold text-neutral-900 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:bg-rose-500">
        Préstamos para Pensionados
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-neutral-500">
        Accede a opciones de financiamiento diseñadas especialmente para pensionados,
        con condiciones competitivas y un proceso sencillo.
      </p>
    </li>

    <li class="w-[85%] shrink-0 snap-center rounded-2xl bg-white p-6 shadow-sm md:w-auto">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-50">
        <Icon name="lucide:refresh-cw" class="h-6 w-6 text-primary" />
      </div>
      <h3 class="relative mt-4 inline-block pb-2 text-base font-semibold text-neutral-900 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:bg-rose-500">
        Refinanciamiento de Préstamos
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-neutral-500">
        Si ya cuentas con un préstamo, te ayudamos a encontrar alternativas que te
        permitan mejorar tus condiciones y reducir el monto de tus pagos mensuales.
      </p>
    </li>

    <li class="w-[85%] shrink-0 snap-center rounded-2xl bg-white p-6 shadow-sm md:w-auto">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-50">
        <Icon name="lucide:landmark" class="h-6 w-6 text-primary" />
      </div>
      <h3 class="relative mt-4 inline-block pb-2 text-base font-semibold text-neutral-900 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:bg-rose-500">
        Comparación entre Financieras
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-neutral-500">
        Analizamos distintas instituciones financieras para encontrar la opción que
        mejor se adapte a tus necesidades.
      </p>
    </li>

    <li class="w-[85%] shrink-0 snap-center rounded-2xl bg-white p-6 shadow-sm md:w-auto">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-50">
        <Icon name="lucide:headset" class="h-6 w-6 text-primary" />
      </div>
      <h3 class="relative mt-4 inline-block pb-2 text-base font-semibold text-neutral-900 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:bg-rose-500">
        Asesoría Personalizada
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-neutral-500">
        Nuestros especialistas te acompañan desde la solicitud hasta la aprobación de
        tu préstamo, resolviendo cualquier duda durante el proceso.
      </p>
    </li>
  </ul>

  <!-- Indicadores (dots) solo en mobile -->
  <div id="carousel-dots" class="mt-4 flex justify-center gap-2 md:hidden">
    <button type="button" data-dot="0" aria-label="Ir a la diapositiva 1" class="h-2 w-2 rounded-full bg-rose-500"></button>
    <button type="button" data-dot="1" aria-label="Ir a la diapositiva 2" class="h-2 w-2 rounded-full bg-neutral-300"></button>
    <button type="button" data-dot="2" aria-label="Ir a la diapositiva 3" class="h-2 w-2 rounded-full bg-neutral-300"></button>
    <button type="button" data-dot="3" aria-label="Ir a la diapositiva 4" class="h-2 w-2 rounded-full bg-neutral-300"></button>
  </div>

  <!-- Banner CTA -->
  <div class="mt-8 flex flex-col gap-4 rounded-2xl bg-rose-50 p-6 md:flex-row md:items-center md:justify-between">
    <div class="flex items-center gap-4">
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-rose-100">
        <Icon name="lucide:users" class="h-6 w-6 text-primary" />
      </div>
      <div>
        <p class="font-semibold text-neutral-900">¿Listo para encontrar un mejor préstamo?</p>
        <p class="text-sm text-neutral-500">
          Descubre las mejores opciones disponibles y recibe asesoría personalizada sin
          compromiso.
        </p>
      </div>
    </div>
    <a
      href="#"
      class="flex shrink-0 items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition hover:bg-rose-700"
    >
      Solicitar préstamo
      <Icon name="lucide:arrow-right" class="h-4 w-4" />
    </a>
  </div>
</section>

<script>
  const track = document.getElementById("services-carousel") as HTMLUListElement | null;
  const prevBtn = document.getElementById("carousel-prev");
  const nextBtn = document.getElementById("carousel-next");
  const dotsWrap = document.getElementById("carousel-dots");

  if (track) {
    const cardWidth = () => (track.firstElementChild as HTMLElement)?.offsetWidth ?? 0;
    const gap = 24; // debe coincidir con el gap-6 (1.5rem = 24px)

    prevBtn?.addEventListener("click", () => {
      track.scrollBy({ left: -(cardWidth() + gap), behavior: "smooth" });
    });

    nextBtn?.addEventListener("click", () => {
      track.scrollBy({ left: cardWidth() + gap, behavior: "smooth" });
    });

    const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll<HTMLButtonElement>("[data-dot]")) : [];

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const index = Number(dot.dataset.dot);
        track.scrollTo({ left: index * (cardWidth() + gap), behavior: "smooth" });
      });
    });

    track.addEventListener("scroll", () => {
      const index = Math.round(track.scrollLeft / (cardWidth() + gap));
      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-rose-500", i === index);
        dot.classList.toggle("bg-neutral-300", i !== index);
      });
    });
  }
</script>