---
import { Icon } from 'astro-icon/components';
---

<div class="w-full h-screen relative overflow-hidden bg-white">

    <!-- corner brackets decoration -->
    <div class="absolute top-6 left-6 w-6 h-6 border-t-2 border-l-2 border-primary/40"></div>
    <div class="absolute top-6 right-6 w-6 h-6 border-t-2 border-r-2 border-primary/40"></div>
    <div class="absolute bottom-6 left-6 w-6 h-6 border-b-2 border-l-2 border-primary/40"></div>
    <div class="absolute bottom-6 right-6 w-6 h-6 border-b-2 border-r-2 border-primary/40"></div>

    <!-- background watermark text -->
    <p class="absolute top-16 left-1/2 -translate-x-1/2 text-[10rem] font-black text-primary/5 whitespace-nowrap select-none pointer-events-none leading-none mb-4">
        SF SENIOR
    </p>

    <!-- "Mejores tasas" label -->
    <div class="absolute top-1/5 translate-y-1/2 left-0 flex items-center gap-2 z-20">
        <div class="w-8 h-px bg-primary"></div>
        <p class="text-xs text-gray-500">Mejores tasas</p>
    </div>

    <!-- "Baja para conocer mas" label -->
    <div class="absolute top-1/3 right-0 flex items-center gap-2 z-20">
        <p class="text-xs text-gray-500 text-right">Baja para<br/>conocer mas</p>
        <div class="w-8 h-px bg-primary"></div>
    </div>

    <!-- dotted pattern decoration -->
    <div class="absolute bottom-24 right-10 grid grid-cols-6 gap-1.5 z-10">
        {Array.from({ length: 30 }).map(() => (
            <span class="w-1 h-1 rounded-full bg-primary/30"></span>
        ))}
    </div>

    <!-- hero image -->
    <img
        src="/heroImage.png"
        alt="Hombre mayor sonriendo con los brazos cruzados"
        class="absolute right-40 scale-130 bottom-0 h-[85%] object-contain z-10"
    />

    <!-- principal content -->
    <div class="max-w-1/2 flex flex-col gap-2 px-8 absolute bottom-28 z-20">
        <h3 class="text-4xl font-bold">No pagues de <span class="text-primary">mas por un prestamo </span></h3>
        <div/>
        <p class="text-sm">Te conseguimos las mejores tasas preferenciales entre nuestras financieras, con nosotros nunca pagaras mas</p>
        <div class="flex gap-4 mt-4">
            <button class="bg-primary text-sm text-white px-4 py-2 rounded-full flex items-center gap-2">
                Simular prestamo
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </button>
            <button class="border border-primary text-sm text-primary px-4 py-2 rounded-full flex items-center gap-2">
                Obten tu prestamo
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </button>
        </div>

        <!-- feature row -->
        <div class="flex items-center gap-5 mt-6">

            <div class="flex items-center gap-2">
                <Icon name="lucide:shield" class="w-6 h-6 text-primary shrink-0" />
                <p class="text-sm leading-tight text-gray-700">Seguros<br/>y confiables</p>
            </div>

            <div class="w-px h-8 bg-primary"></div>

            <div class="flex items-center gap-2">
                <Icon name="lucide:scissors" class="w-6 h-6 text-primary shrink-0" />
                <p class="text-sm leading-tight text-gray-700">Tasas<br/>preferenciales</p>
            </div>

            <div class="w-px h-8 bg-primary"></div>

            <div class="flex items-center gap-2">
                <Icon name="lucide:file-text" class="w-6 h-6 text-primary shrink-0" />
                <p class="text-sm leading-tight text-gray-700">Sin tramites<br/>complicados</p>
            </div>
        </div>
    </div>

    <!-- footer hero -->
    <div class="w-[45vw] px-6 py-3 absolute -bottom-2 left-1/2 -translate-1/2 bg-white shadow-lg rounded-full flex items-center justify-between gap-4 z-20">

        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <Icon name="lucide:users" class="w-5 h-5 text-primary" />
            </div>
            <p class="text-sm text-gray-700 leading-tight">
                Miles de pensionados ya mejoraron su calidad de vida<br/>
                con un prestamo justo y transparente
            </p>
        </div>

        <div class="flex items-center shrink-0">
            <img src="https://images.pexels.com/photos/17042305/pexels-photo-17042305.jpeg" alt="" class="w-9 h-9 rounded-full object-cover border-2 border-white -mr-3" />
            <img src="https://images.pexels.com/photos/33106773/pexels-photo-33106773.jpeg" alt="" class="w-9 h-9 rounded-full object-cover border-2 border-white -mr-3" />
            <img src="https://images.pexels.com/photos/7544891/pexels-photo-7544891.jpeg" alt="" class="w-9 h-9 rounded-full object-cover border-2 border-white" />
        </div>

    </div>

</div>