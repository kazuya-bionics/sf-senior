---
import { Icon } from 'astro-icon/components';
---

<div class="w-full min-h-screen md:h-screen relative overflow-hidden bg-white">

    <!-- corner brackets decoration -->
    <div class="absolute top-4 left-4 md:top-6 md:left-6 w-5 h-5 md:w-6 md:h-6 border-t-2 border-l-2 border-primary/40"></div>
    <div class="absolute top-4 right-4 md:top-6 md:right-6 w-5 h-5 md:w-6 md:h-6 border-t-2 border-r-2 border-primary/40"></div>
    <div class="absolute bottom-4 left-4 md:bottom-6 md:left-6 w-5 h-5 md:w-6 md:h-6 border-b-2 border-l-2 border-primary/40"></div>
    <div class="absolute bottom-4 right-4 md:bottom-6 md:right-6 w-5 h-5 md:w-6 md:h-6 border-b-2 border-r-2 border-primary/40"></div>

    <!-- background watermark text (solo desktop, en mobile compite con el contenido) -->
    <p class="hidden md:block absolute top-16 left-1/2 -translate-x-1/2 text-[10rem] font-black text-primary/5 whitespace-nowrap select-none pointer-events-none leading-none mb-4">
        SF SENIOR
    </p>

    <!-- "Mejores tasas" label (solo desktop) -->
    <div class="hidden md:flex absolute top-1/5 translate-y-1/2 left-0 items-center gap-2 z-20">
        <div class="w-8 h-px bg-primary"></div>
        <p class="text-xs text-gray-500">Mejores tasas</p>
    </div>

    <!-- "Baja para conocer mas" label (solo desktop) -->
    <div class="hidden md:flex absolute top-1/3 right-0 items-center gap-2 z-20">
        <p class="text-xs text-gray-500 text-right">Baja para<br/>conocer mas</p>
        <div class="w-8 h-px bg-primary"></div>
    </div>

    <!-- dotted pattern decoration (solo desktop) -->
    <div class="hidden md:grid absolute bottom-24 right-10 grid-cols-6 gap-1.5 z-10">
        {Array.from({ length: 30 }).map(() => (
            <span class="w-1 h-1 rounded-full bg-primary/30"></span>
        ))}
    </div>

    <!-- hero image -->
    <img
        src="/heroImage.png"
        alt="Hombre mayor sonriendo con los brazos cruzados"
        class="relative md:absolute mx-auto md:mx-0 md:right-40 md:bottom-0 mt-6 md:mt-0 w-48 sm:w-64 md:w-auto h-auto md:h-[85%] md:scale-130 object-contain z-10"
    />

    <!-- principal content -->
    <div class="relative md:absolute md:max-w-1/2 md:bottom-28 w-full flex flex-col items-center md:items-start gap-2 px-6 md:px-8 mt-6 md:mt-0 text-center md:text-left z-20">
        <h3 class="text-3xl sm:text-4xl font-bold">No pagues de <span class="text-primary">mas por un prestamo </span></h3>
        <div/>
        <p class="text-sm max-w-sm md:max-w-none">Te conseguimos las mejores tasas preferenciales entre nuestras financieras, con nosotros nunca pagaras mas</p>
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mt-4 w-full sm:w-auto items-center">
            <button class="bg-primary text-sm text-white px-4 py-2 rounded-full flex items-center justify-center gap-2 w-full sm:w-auto">
                Simular prestamo
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </button>
            <button class="border border-primary text-sm text-primary px-4 py-2 rounded-full flex items-center justify-center gap-2 w-full sm:w-auto">
                Obten tu prestamo
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </button>
        </div>

        <!-- feature row -->
        <div class="flex flex-wrap justify-center md:justify-start items-center gap-x-5 gap-y-3 mt-6">

            <div class="flex items-center gap-2">
                <Icon name="lucide:shield" class="w-6 h-6 text-primary shrink-0" />
                <p class="text-sm leading-tight text-gray-700 text-left">Seguros<br/>y confiables</p>
            </div>

            <div class="hidden sm:block w-px h-8 bg-primary"></div>

            <div class="flex items-center gap-2">
                <Icon name="lucide:scissors" class="w-6 h-6 text-primary shrink-0" />
                <p class="text-sm leading-tight text-gray-700 text-left">Tasas<br/>preferenciales</p>
            </div>

            <div class="hidden sm:block w-px h-8 bg-primary"></div>

            <div class="flex items-center gap-2">
                <Icon name="lucide:file-text" class="w-6 h-6 text-primary shrink-0" />
                <p class="text-sm leading-tight text-gray-700 text-left">Sin tramites<br/>complicados</p>
            </div>
        </div>
    </div>

    <!-- footer hero -->
    <div class="relative md:absolute w-[92%] max-w-md md:max-w-none md:w-[45vw] mx-auto md:mx-0 md:left-1/2 md:-bottom-2 md:-translate-1/2 px-6 py-4 md:py-3 mt-8 mb-8 md:mt-0 md:mb-0 bg-white shadow-lg rounded-3xl md:rounded-full flex flex-col sm:flex-row items-center justify-between gap-4 z-20">

        <div class="flex items-center gap-3 text-center sm:text-left">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <Icon name="lucide:users" class="w-5 h-5 text-primary" />
            </div>
            <p class="text-sm text-gray-700 leading-tight">
                Miles de pensionados ya mejoraron su calidad de vida
                con un prestamo justo y transparente
            </p>
        </div>

        <div class="flex items-center shrink-0">
            <img src="https://images.pexels.com/photos/17042305/pexels-photo-17042305.jpeg" alt="" class="w-9 h-9 rounded-full object-cover border-2 border-white -mr-3" />
            <img src="https://images.pexels.com/photos/33106773/pexels-photo-33106773.jpeg" alt="" class="w-9 h-9 rounded-full object-cover border-2 border-white -mr-3" />
            <img src="https://images.pexels.com/photos/7544891/pexels-photo-7544891.jpeg" alt="" class="w-9 h-9 rounded-full object-cover border-2 border-white" />
        </div>

    </div>

</div>